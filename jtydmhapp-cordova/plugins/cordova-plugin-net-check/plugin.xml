<?xml version='1.0' encoding='utf-8'?>
<plugin id="cordova-plugin-net-check" version="1.0.0" xmlns="http://apache.org/cordova/ns/plugins/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>NetworkPlugin</name>
    <js-module name="NetworkPlugin" src="www/NetworkPlugin.js">
        <clobbers target="NetworkPlugin" />
    </js-module>
    <platform name="ios">
        <config-file parent="/*" target="config.xml">
            <feature name="NetworkPlugin">
                <param name="ios-package" value="NetworkPlugin" />
            </feature>
        </config-file>
        <source-file src="src/ios/NetworkPlugin.h" />
        <source-file src="src/ios/NetworkPlugin.m" />
        <source-file src="src/ios/CLAPIClient.h" />
        <source-file src="src/ios/CLAPIClient.m" />
    </platform>
</plugin>
